;; Vars
(defpoll bat :interval "2h" "bash ./scripts/battery.sh --bat")
(defpoll bat.status :interval "10s" "bash ./scripts/battery.sh --status")
(defpoll current_time :interval "1s" "date +%H:%M:%S")
(defpoll day :interval "1h" "date +%d")
(defpoll month :interval "24h" "date +%m")
(defpoll year :interval "24h" "date +%Y")
(defvar rev false)

;; Windows
(defwindow rightbar
  :monitor 0
  :exclusive true
  :geometry (geometry
             :x "0%"
             :y "0%"
             :heght "15%"
             :anchor "top right")
  :stacking "fg"
  (_right))

(defwindow calendar
  :monitor 0
  :exclusive false
  :stacking "fg"
  :geometry (geometry
              :anchor "top right"
              :y "4%")
  (_cal))

;; Widgets aggrgetors
(defwidget _right []
  (box :halign "end" :valign "fill" :orientation "h" :spacing 10 :space-evenly false
    (_clock)
    (_bat :battery bat :status bat.status)
    (_power)))

;; Widgets
(defwidget _cal []
  (box
    (calendar
      :day day
      :month month
      :year year
      :show-details true
      :show-day-names true
      :show-week-numbers false
      :show-heading true)))

(defwidget _clock []
  (box :valign "center" :halign "end"
    (button :onclick "bash ./scripts/pop.sh cal"
    (label :text current_time))))

(defwidget _bat [battery status]
  (box :valign "fill" :halign "end"
    (label :class "bat-icon" :text {battery == "AC" ? "":
      status == "Charging" ? "" :
      battery >= 90 ? "" :
      battery >= 60 ? "" :
      battery >= 30 ? "" :
      battery >= 10 ? "" :
      ""})
    (label :text {status})))

(defwidget _power []
  (eventbox :halign "start" :onhover "eww update rev=true" :onhoverlost "eww update rev=false" :onclick "systemctl poweroff"
    (box :valign "center" :halign "end" :space-evenly false
      (revealer :transition "slideleft" :reveal rev :class "bat-icon" :hexpand true :width "px"
        (box :hexpand false :halign "start"
          (button :onclick "systemctl reboot" (label :text ""))
          (button :onclick "swaylock" (label :text ""))
          (button :onclick "systemctl suspend" (label :text ""))
          (button :onclick "loginctl terminate-user $USER" (label :text ""))))
      (label :text "" :halign "start"))))


