(defwindow topbar
  :monitor 0
  :geometry (geometry
              :x "0%"
              :y "0%"
              :width "100%"
              :height "10px"
              :anchor "top center")
  :stacking "fg"
  :exclusive true
  :windowtype "dock"
  (aggregator))

(defpoll time :interval "1s"
  `date +%T`)

(defwidget aggregator []
  (eventbox :onclick "eww -c ../calendar open calendar"
    (box :orientation "h" :space-evenly false :halign "end" :class "time"
      (label :text time))))

