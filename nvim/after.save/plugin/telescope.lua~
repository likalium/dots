local map=vim.keymap.set
-- FILE pickers
map("n","<leader>ff","<cmd>Telescope find_files<CR>",{}) -- Files Files
map("n","<leader>fg","<cmd>Telescope git_files<CR>",{}) -- Files Git
map("n","<leader>fr","<cmd>Telescope grep_string<CR>",{}) -- Files gRep
map("n","<leader>fl","cmd>",{}) -- Files Live

-- VIM pickers
map("n","<leader>vb","<cmd>Telescope buffers<CR>",{}) -- Vim Buffers
map("n","<leader>vc","<cmd>Telescope command_history<CR>",{}) -- Vim Command history
map("n","<leader>vs","<cmd>Telescope search_history",{}) -- Vim Search hisotry
map('n','<leader>vm',"<cmd>",{}) -- Vim Marks

-- GIT pickers
map('n','<leader>gc',"<cmd>",{}) -- Git Commits
map('n','<leader>gb',"<cmd>",{}) -- Git Branches
map('n','<leader>gs',"<cmd>",{}) -- Git Status

-- TREESITTER pickers
map('n','<leader>tr',"<cmd>",{}) -- TReesitter

-- LISTS PICKERS
map('n','<leader>lp',"<cmd>",{}) -- Lists Planets
