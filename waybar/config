{
	"layer": "top",
	"position": "top",
	"height": 35,
	"modules-left": [],
	"modules-center": [],
	"modules-right": ["battery", "clock"],
	"margin": 3,
	"mode": "dock",
	"battery": {
		"interval": 30,
		"states": {
			"full": 100,
			"good": 75,
			"mid": 50,
			"low": 25,
			"warning": 10,
		},
		"format-time": "{H}:{M}",
		"format-icons": ["","", "", "", ""],
	},
	"clock": {
		"interval": 1,
		"format": "{:%H:%M:%S}",
		"timezone": "Europe/Paris",
	},
}
